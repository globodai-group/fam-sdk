# =============================================================================
# FAM SDK — credentials provisioned by the FAM admin at site ID creation.
#
# Copy this file to `.env` (gitignored) in your consumer app and fill in the
# values you received. Use a different site ID — and therefore different
# values — for each environment (dev / staging / production).
#
# NEVER commit real values. Use a secret manager in CI/CD.
# =============================================================================

# Base URL of the FAM API (one URL per environment: sandbox / staging / prod).
# The SDK refuses http:// outside of localhost in any environment.
FAM_API_BASE_URL=https://api.sandbox.fam.com

# Backend secret token — full read/write access. SERVER ONLY.
# Never bundle into a frontend, mobile app, or public repo.
FAM_API_SECRET=fam_sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public key — read-only (GET-only). Safe to embed in frontend / mobile bundles.
FAM_API_PUBLIC_KEY=fam_pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HMAC SHA-256 secret used to verify incoming webhook signatures.
# Required: instantiating Webhooks without it throws.
FAM_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
